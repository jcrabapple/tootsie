<?xml version="1.0" encoding="utf-8"?>
<!-- Collection metadata header for CollectionDetailFragment (Tootsie / FEP-7aa9).
     Renders the collection's title, description, member count, language,
     hashtag badge, and creation/update timestamps above the member account list. -->
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:orientation="vertical"
	android:paddingStart="16dp"
	android:paddingEnd="16dp"
	android:paddingTop="12dp"
	android:paddingBottom="12dp"
	android:background="?colorM3SurfaceVariant"
	android:elevation="2dp">

	<!-- Title: collection name (e.g. "Notable Fediverse Creators") -->
	<TextView
		android:id="@+id/collection_title"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:textAppearance="@style/m3_headline_small"
		android:textColor="?colorM3OnSurface"
		android:singleLine="false"
		android:textIsSelectable="true"/>

	<!-- Description: collection purpose/description (optional, shows placeholder if empty) -->
	<TextView
		android:id="@+id/collection_description"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="4dp"
		android:textAppearance="@style/m3_body_medium"
		android:textColor="?colorM3OnSurfaceVariant"
		android:singleLine="false"
		android:textIsSelectable="true"/>

	<!-- Subtitle: member count + language (e.g. "12 members · EN") -->
	<TextView
		android:id="@+id/collection_subtitle"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="8dp"
		android:textAppearance="@style/m3_body_small"
		android:textColor="?colorM3OnSurfaceVariant"/>

	<!-- Hashtag badge: optional topic tag (e.g. "#art") -->
	<TextView
		android:id="@+id/collection_hashtag"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginTop="6dp"
		android:paddingStart="10dp"
		android:paddingEnd="10dp"
		android:paddingTop="4dp"
		android:paddingBottom="4dp"
		android:textAppearance="@style/m3_label_small"
		android:textColor="?colorM3Primary"
		android:background="@drawable/bg_collection_hashtag_pill"
		android:visibility="gone"/>

	<!-- Timestamps: creation date (optional) -->
	<TextView
		android:id="@+id/collection_created_at"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="8dp"
		android:textAppearance="@style/m3_label_small"
		android:textColor="?colorM3OnSurfaceVariant"
		android:visibility="gone"/>

	<!-- Timestamps: last updated (optional, shown when differ from created) -->
	<TextView
		android:id="@+id/collection_updated_at"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:textAppearance="@style/m3_label_small"
		android:textColor="?colorM3OnSurfaceVariant"
		android:visibility="gone"/>

</LinearLayout>